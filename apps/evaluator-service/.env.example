# Mock Mode Configuration
# Set to 'true' to use mock/test data instead of Azure AI Foundry
# Set to 'false' to use real Azure integration (requires Azure credentials below)
USE_MOCK_DATA=true

# Service Configuration
EVALUATOR_SERVICE_PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Azure AI Foundry Configuration (only required when USE_MOCK_DATA=false)
AZURE_AI_FOUNDRY_ENDPOINT=https://your-endpoint.azure.com
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
